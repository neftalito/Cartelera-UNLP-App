<?xml version="1.0" encoding="utf-8"?>
<!-- Declara permisos, componentes y reglas de entrada de la aplicación Android. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".UNLPCarteleraNotifierApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UNLPCarteleraNotifier">
        <meta-data
            android:name="firebase_messaging_installation_id_enabled"
            android:value="true" />

        <!-- La app inicializa Firebase manualmente desde BuildConfig en Application. -->
        <provider
            android:name="com.google.firebase.provider.FirebaseInitProvider"
            android:authorities="${applicationId}.firebaseinitprovider"
            tools:node="remove" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.UNLPCarteleraNotifier">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Los extras de notificación sólo ingresan por esta actividad interna. -->
        <activity
            android:name=".push.NotificationOpenActivity"
            android:exported="false"
            android:noHistory="true"
            android:relinquishTaskIdentity="true"
            android:theme="@android:style/Theme.NoDisplay" />

        <service
            android:name=".push.CarteleraFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
